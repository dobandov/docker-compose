pipeline {
    agent {
        node {
            label '' 
            // Jenkins usará esta subcarpeta como base para TODO el pipeline
            customWorkspace "${env.WORKSPACE}/keycloak/24"
        }
    }

    stages {
        stage('Validar') {
            steps {
                // Aquí ya estás dentro de keycloak/24 automáticamente
                sh 'ls -laR'
            }
        }
        stage('Build') {
            steps {
                // No necesitas dir() aquí tampoco
                sh 'docker build -t mi-app .'
            }
        }
    }
}