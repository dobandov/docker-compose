pipeline {
    agent {
        node {
            // Jenkins usará esta subcarpeta como base para TODO el pipeline
            customWorkspace "${env.WORKSPACE}/keycloak/24"
        }
    }
    stages {
        stage('Validar Archivos2') {
            steps {
                    sh '''
                        echo "Trabajando en: $(pwd)"
                        echo "--- Listando archivos pre---"
                        ls -F
                    '''
            }
        }
        stage('Validar Archivos') {
            steps {
                // Nos movemos a la subcarpeta del proyecto
                dir('keycloak/24') {
                    sh '''
                        echo "Trabajando en: $(pwd)"
                        echo "--- Listando archivos ---"
                        ls -F
                    '''
                }
            }
        }
        
        stage('Docker Info') {
            steps {
                dir('keycloak/24') {
                    // Aquí ya podrías hacer un build usando el Dockerfile de esa carpeta
                    sh 'docker build -t mi-keycloak-custom:latest .'
                }
            }
        }
    }
}