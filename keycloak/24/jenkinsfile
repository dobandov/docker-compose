pipeline {
    agent any

    stages {
        stage('Keycloak Context') {
            steps {
                script {
                    // Todo lo que ocurra dentro de este bloque dir 
                    // respetará la jerarquía de stages para la UI de Jenkins
                    dir('keycloak/24') {
                        // Llamamos a los stages internos
                        stage('Validar') {
                            sh 'ls -laR'
                        }
                        stage('Build') {
                            sh 'ls -laR'
                        }
                        stage('Test') {
                            sh 'echo "Haciendo tests en $(pwd)"'
                        }
                    }
                }
            }
        }
    }
}